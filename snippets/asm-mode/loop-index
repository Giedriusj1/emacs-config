# -*- mode: snippet -*-
# name: indexed-loop-with-aliases
# key: loop-index
# --
${1:index} .req ${2:x0}
${3:count} .req ${4:x1}

        mov $1, #0
${5:loop}:
        cmp $1, $3
        b.${6:ge} ${7:done}
        ${8:// body}
        add $1, $1, #1
        b $5

$7:
        .unreq $1
        .unreq $3
